///usr/bin/env jbang "$0" "$@" ; exit $?
//REPOS mavencentral,confluent-packages=https://packages.confluent.io/maven/
//DEPS info.picocli:picocli:4.6.3
//DEPS org.apache.kafka:kafka-clients:4.3.0
//DEPS com.fasterxml.jackson.core:jackson-databind:2.22.0
//DEPS com.fasterxml.jackson.datatype:jackson-datatype-jsr310:2.22.0
//DEPS io.confluent:kafka-avro-serializer:8.3.0
//SOURCES model/User.java
//SOURCES model/PersonOuterClass.java

import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.json.JsonMapper;

import io.confluent.kafka.serializers.KafkaAvroDeserializer;
import io.confluent.kafka.serializers.KafkaAvroDeserializerConfig;

import java.time.Duration;
import java.util.Properties;
import java.util.concurrent.Callable;
import java.util.concurrent.atomic.AtomicBoolean;

import model.PersonOuterClass.Person;
import model.User;

import org.apache.kafka.clients.consumer.ConsumerConfig;
import org.apache.kafka.clients.consumer.KafkaConsumer;
import org.apache.kafka.common.serialization.Deserializer;
import org.apache.kafka.common.serialization.IntegerDeserializer;
import org.apache.kafka.common.serialization.StringDeserializer;

import picocli.CommandLine;
import picocli.CommandLine.Command;
import picocli.CommandLine.Option;

@Command(name = "consume-demo-records", mixinStandardHelpOptions = true,
        description = "Consume demo records produced by produce-records.")
public class ConsumeDemoRecords implements Callable<Integer> {

    private static final ObjectMapper MAPPER = new ObjectMapper();

    @Option(names = "--bootstrap-servers", defaultValue = "localhost:29092,localhost:29093,localhost:29094",
            description = "Kafka bootstrap servers.")
    String bootstrapServers;

    @Option(names = "--topic", required = true, description = "Topic to subscribe to.")
    String topic;

    @Option(names = "--group", required = true, description = "Consumer group id.")
    String groupId;

    @Option(names = "--format", required = true, description = "Value format: json, protobuf, or avro.")
    String format;

    @Option(names = "--schema-registry-url", defaultValue = "http://localhost:8081",
            description = "Schema Registry URL (required for avro).")
    String schemaRegistryUrl;

    @Option(names = "--instance-id", required = true, description = "Unique consumer instance id.")
    String instanceId;

    public static void main(String... args) {
        System.exit(new CommandLine(new ConsumeDemoRecords()).execute(args));
    }

    @Override
    public Integer call() {
        var running = new AtomicBoolean(true);
        Runtime.getRuntime().addShutdownHook(new Thread(() -> running.set(false)));

        try (var consumer = consumer()) {
            consumer.subscribe(java.util.List.of(topic));
            System.out.printf("Consumer %s joined group %s on topic %s (%s)%n",
                              instanceId, groupId, topic, format);
            while (running.get()) {
                var records = consumer.poll(Duration.ofSeconds(1));
                for (var record : records) {
                    System.out.printf("[%s] key=%s value=%s%n",
                                      instanceId,
                                      record.key(),
                                      formatValue(record.value()));
                }
            }
        } catch (Exception e) {
            System.err.printf("Consumer %s failed: %s%n", instanceId, e.getMessage());
            e.printStackTrace();
            return 1;
        }
        return 0;
    }

    private String formatValue(Object value) {
        return switch (format.toLowerCase()) {
            case "json" -> {
                var user = (User) value;
                yield "User{id=%d, username=%s}".formatted(user.id(), user.username());
            }
            case "protobuf" -> {
                var person = (Person) value;
                yield "Person{id=%d, name=%s, email=%s}".formatted(person.getId(), person.getName(), person.getEmail());
            }
            case "avro" -> value.toString();
            default -> throw new IllegalArgumentException("Unsupported format: " + format);
        };
    }

    @SuppressWarnings("unchecked")
    private KafkaConsumer<Integer, Object> consumer() {
        var props = new Properties();
        props.put(ConsumerConfig.BOOTSTRAP_SERVERS_CONFIG, bootstrapServers);
        props.put(ConsumerConfig.GROUP_ID_CONFIG, groupId);
        props.put(ConsumerConfig.CLIENT_ID_CONFIG, "%s-%s".formatted(groupId, instanceId));
        props.put(ConsumerConfig.KEY_DESERIALIZER_CLASS_CONFIG, IntegerDeserializer.class);
        props.put(ConsumerConfig.VALUE_DESERIALIZER_CLASS_CONFIG, valueDeserializerClass());
        props.put(ConsumerConfig.AUTO_OFFSET_RESET_CONFIG, "earliest");
        props.put(ConsumerConfig.ENABLE_AUTO_COMMIT_CONFIG, "true");
        if ("avro".equalsIgnoreCase(format)) {
            props.put(KafkaAvroDeserializerConfig.SCHEMA_REGISTRY_URL_CONFIG, schemaRegistryUrl);
            props.put(KafkaAvroDeserializerConfig.SPECIFIC_AVRO_READER_CONFIG, false);
        }
        return new KafkaConsumer<>(props);
    }

    private Class<? extends Deserializer<?>> valueDeserializerClass() {
        return switch (format.toLowerCase()) {
            case "json" -> JsonUserDeserializer.class;
            case "protobuf" -> ProtobufPersonDeserializer.class;
            case "avro" -> KafkaAvroDeserializer.class;
            default -> throw new IllegalArgumentException("Unsupported format: " + format);
        };
    }

    public static final class JsonUserDeserializer implements Deserializer<User> {
        private final ObjectMapper mapper = JsonMapper.builder().findAndAddModules().build();

        @Override
        public User deserialize(String topic, byte[] data) {
            try {
                return mapper.readValue(data, User.class);
            } catch (Exception e) {
                throw new RuntimeException("Failed to deserialize User", e);
            }
        }
    }

    public static final class ProtobufPersonDeserializer implements Deserializer<Person> {
        @Override
        public Person deserialize(String topic, byte[] data) {
            try {
                return Person.parseFrom(data);
            } catch (Exception e) {
                throw new RuntimeException("Failed to deserialize Person", e);
            }
        }
    }
}
